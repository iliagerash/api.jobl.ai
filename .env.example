APP_NAME="Jobl API"
APP_VERSION="0.1.0"
API_PREFIX="/v1"
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/jobl"

# Normalizer (optional — rules-only fallback if not set)
MODEL_DIR=/opt/jobl/models/normalizer
NUM_BEAMS=4
MAX_NEW_TOKENS=32
MAX_INPUT_LENGTH=128

# Categorizer (optional — category field is null if not set)
CATEGORIZER_MODEL_PATH=/opt/jobl/models/categorizer.pkl

# Sync worker
SOURCE_DB_HOST=mysql.example.com
SOURCE_DB_PORT=3306
SOURCE_DB_USER=sync_user
SOURCE_DB_PASSWORD=changeme
# SOURCE_DB_DRIVER=mysql+pymysql  (default)
# SOURCE_DB_SSL_DISABLED=true     (default)
EXPORT_DESTINATION=jobl.ai
# SYNC_BATCH_SIZE=1000            (default)
