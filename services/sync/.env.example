LOG_LEVEL="INFO"
SYNC_BATCH_SIZE=1000
SYNC_INTERVAL_SECONDS=3600

# Source (scraper host; DB name comes from target `source_countries`)
SOURCE_DB_DRIVER="mysql+pymysql"
SOURCE_DB_HOST="localhost"
SOURCE_DB_PORT=3306
SOURCE_DB_USER="user"
SOURCE_DB_PASSWORD="pass"

# Target (AI host Postgres)
TARGET_DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/jobl"

EXPORT_DESTINATION="jobl.ai"
